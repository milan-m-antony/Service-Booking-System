# Service Booking System - Environment Variables
# Copy this file to .env and fill in actual values for your environment

# ============================================================================
# DATABASE
# ============================================================================
# TiDB Cloud Connection String (MySQL-compatible)
# Format: mysql://USERNAME:PASSWORD@HOST:PORT/DATABASE?ssl=true
DATABASE_URL=mysql://2nY23AcjqeH665b.root:m9ZlIZu4P9nESsM@gateway01.ap-southeast-1.prod.aws.tidbcloud.com:4000/myapp_db?ssl=true

# ============================================================================
# SECURITY
# ============================================================================
# Django Secret Key - Generate a strong random value
# You can generate one using: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-super-secret-key-here-generate-a-random-one

# Debug mode (NEVER set to True in production)
DEBUG=false

# ============================================================================
# ALLOWED HOSTS & CSRF
# ============================================================================
# Comma-separated list of allowed hostnames
# For Render: your-service-name.onrender.com
# For local: localhost,127.0.0.1
ALLOWED_HOSTS=localhost,127.0.0.1,your-service-name.onrender.com

# Comma-separated list of allowed origins for CSRF
# Must include https:// for production
CSRF_TRUSTED_ORIGINS=http://localhost:3000,https://your-service-name.onrender.com

# ============================================================================
# OPTIONAL: FILE STORAGE (S3 / Media Files)
# ============================================================================
# Uncomment and fill if using AWS S3 for media storage

# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=us-east-1
# AWS_S3_CUSTOM_DOMAIN=your-bucket-name.s3.amazonaws.com
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# ============================================================================
# RENDER-SPECIFIC
# ============================================================================
# Note: Render automatically injects PORT environment variable
# No need to set it manually
# PORT is handled by Gunicorn in startCommand: --bind 0.0.0.0:$PORT
